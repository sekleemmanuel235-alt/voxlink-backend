# ─────────────────────────────────────────────────────────────────
# VoxLink Backend — Variables d'environnement
# Copier ce fichier en .env et remplir vos vraies clés
# NE JAMAIS committer le fichier .env sur GitHub
# ─────────────────────────────────────────────────────────────────

# Base de données (SQLite par défaut, PostgreSQL recommandé en prod)
# DATABASE_URL=postgresql://user:password@host:5432/voxlink_db

# Cache Redis (optionnel mais recommandé)
# REDIS_URL=redis://localhost:6379/0

# OpenRouter — Moteur de traduction IA
# Obtenir sur https://openrouter.ai → Dashboard → API Keys
OPENROUTER_API_KEY=sk-or-v1-VOTRE_CLE_ICI

# ElevenLabs — Clonage et synthèse vocale
# Obtenir sur https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=sk_VOTRE_CLE_ICI

# RevenueCat — Gestion des abonnements Premium
# Obtenir sur https://app.revenuecat.com → Project → API Keys → Secret Key
REVENUECAT_API_KEY=VOTRE_CLE_SERVEUR_ICI
